# ==============================================================================
# Roomix — .gitignore
# Comprehensive ignore rules for Flutter/Dart/Firebase project
# ==============================================================================

# ──────────────────────────────────────────────
# Flutter / Dart
# ──────────────────────────────────────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
build/
**/doc/api/
*.dart.js
*.js_
*.js.deps
*.js.map

# Flutter-generated metadata
.metadata
.packages

# Pub lock file (recommended to track for apps, but we keep it clean)
# If you want reproducible builds, remove the next line:
# pubspec.lock

# ──────────────────────────────────────────────
# Android
# ──────────────────────────────────────────────
**/android/**/gradle-wrapper.jar
**/android/.gradle/
**/android/.idea/
**/android/.kotlin/
**/android/captures/
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
**/android/build/
**/android/app/build/
**/android/.cxx/

# Keystores — NEVER commit signing keys
*.jks
*.keystore
key.properties

# ──────────────────────────────────────────────
# iOS / macOS
# ──────────────────────────────────────────────
**/ios/Flutter/.last_build_id
**/ios/Pods/
**/ios/.symlinks/
**/ios/DerivedData/
**/ios/**/*.dSYM/
**/macos/Flutter/ephemeral/
**/macos/Pods/

# ──────────────────────────────────────────────
# Web
# ──────────────────────────────────────────────
# (web/ source files are tracked; build output goes to build/)

# ──────────────────────────────────────────────
# Windows / Linux
# ──────────────────────────────────────────────
**/windows/flutter/ephemeral/
**/linux/flutter/ephemeral/

# ──────────────────────────────────────────────
# IDE — IntelliJ / Android Studio
# ──────────────────────────────────────────────
.idea/
**/.idea/
*.iml
*.ipr
*.iws
.run/

# ──────────────────────────────────────────────
# IDE — VS Code
# ──────────────────────────────────────────────
.vscode/

# ──────────────────────────────────────────────
# Credentials & Secrets
# ──────────────────────────────────────────────
# Firebase / Google service configs (contain API keys)
google-services.json
**/google-services.json
GoogleService-Info.plist
**/GoogleService-Info.plist

# Google OAuth client secrets
client_secret_*.json
**/client_secret_*.json

# Entire credentials directory
datacreds/

# Environment files
.env
.env.*
!.env.example

# Certificate / key files
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

# Map API key config files
lib/maps_keys/

# ──────────────────────────────────────────────
# Build Artifacts
# ──────────────────────────────────────────────
*.apk
*.aab
*.ipa
*.dSYM/
*.xcarchive/

# ──────────────────────────────────────────────
# Design References & Screenshots (not source code)
# ──────────────────────────────────────────────
stitch_new_app_desing/
fr_db/

# ──────────────────────────────────────────────
# Development / Debug Artifacts
# ──────────────────────────────────────────────
build_errors.txt
devices.txt
dart-defines.json
*.log
coverage/

# ──────────────────────────────────────────────
# OS-generated files
# ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
desktop.ini
$RECYCLE.BIN/

# ──────────────────────────────────────────────
# Miscellaneous
# ──────────────────────────────────────────────
*.class
*.pyc
*.swp
*.swo
*~
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# Node modules (if backend exists)
node_modules/
**/node_modules/
