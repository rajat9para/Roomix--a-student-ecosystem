# ==============================================================================
# Roomix — Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!
# ==============================================================================

# ─────────────────────────────────────────────────
# Firebase Configuration
# ─────────────────────────────────────────────────
# These are optional — the app uses lib/firebase_options.dart by default.
# Use these only if injecting config at build time via --dart-define.

FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_firebase_app_id

# ─────────────────────────────────────────────────
# Map Configuration
# ─────────────────────────────────────────────────
# MapMyIndia API key for static maps, search, and geocoding.
# Get your key from: https://www.mapmyindia.com/
# Also set in android/local.properties as mapmyindia.api.key

MAPMYINDIA_API_KEY=your_mapmyindia_api_key

# ─────────────────────────────────────────────────
# Backend URL (Optional)
# ─────────────────────────────────────────────────
# Only needed if using a custom backend alongside Firebase.

FLUTTER_BACKEND_URL=https://your-backend-url.com

# ─────────────────────────────────────────────────
# Admin Configuration
# ─────────────────────────────────────────────────
# Admin email for OTP-based login (must match Firebase Auth record).

ADMIN_EMAIL=your_admin_email@example.com

# ─────────────────────────────────────────────────
# Support Configuration
# ─────────────────────────────────────────────────
# Support email shown on the Help & Support screen.

SUPPORT_EMAIL=your_support_email@example.com

# ─────────────────────────────────────────────────
# Build Configuration
# ─────────────────────────────────────────────────
# Environment: development | staging | production
APP_ENV=development

# Enable debug logging
DEBUG_MODE=true
