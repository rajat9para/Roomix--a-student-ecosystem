# Android-specific .gitignore for Roomix
# ──────────────────────────────────────────────

# Gradle
gradle-wrapper.jar
/.gradle/
/.kotlin/

# Build outputs
/build/
/app/build/
/captures/

# Gradle wrapper scripts (regenerated by wrapper task)
/gradlew
/gradlew.bat

# Local configuration (machine-specific paths & API keys)
/local.properties

# Generated plugin registrant
GeneratedPluginRegistrant.java

# Native build intermediates
.cxx/

# Keystores — NEVER commit signing keys
key.properties
**/*.keystore
**/*.jks

# IDE
*.iml
/.idea/

# OS
.DS_Store
Thumbs.db
desktop.ini
